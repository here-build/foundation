{
  "compilerOptions": {
    "importHelpers": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    // target ES2024 downcompiles accessor to get/set (Rollup can't parse TC39 accessor)
    // lib esnext keeps iterator helper types available (runtime supports them)
    // ^^^ NOTE: target+lib are set by env configs, not here. Comment kept for context.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": true,
    "isolatedModules": true
  }
}
