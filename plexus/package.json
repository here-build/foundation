{
  "name": "@here.build/plexus",
  "version": "0.1.0",
  "description": "Constraint network for object state superposition through mathematical field dynamics",
  "keywords": [
    "constraint",
    "field",
    "mathematics",
    "model",
    "proxy",
    "superposition"
  ],
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mobx": {
      "types": "./dist/mobx/index.d.ts",
      "import": "./dist/mobx/index.js",
      "require": "./dist/mobx/index.js",
      "default": "./dist/mobx/index.js"
    },
    "./mobx/register": {
      "types": "./dist/mobx/register.d.ts",
      "import": "./dist/mobx/register.js",
      "require": "./dist/mobx/register.js",
      "default": "./dist/mobx/register.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --config vitest.config.varianced.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@here.build/arrival-env": "workspace:^",
    "@here.build/collections": "workspace:^",
    "lib0": "0.2.114",
    "nanoid": "5.1.5",
    "tiny-invariant": "1.3.3",
    "type-fest": "5.4.4"
  },
  "devDependencies": {
    "@here.build/eslint-configs": "workspace:^",
    "@here.build/tsconfig": "workspace:^",
    "@types/node": "24.0.0",
    "@types/ws": "8.18.1",
    "eslint": "9.39.2",
    "fast-check": "4.5.3",
    "mobx": "6.15.0",
    "prettier": "3.8.1",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.0",
    "ws": "8.18.3",
    "y-protocols": "1.0.6",
    "y-websocket": "3.0.0",
    "yjs": "13.6.30"
  },
  "peerDependencies": {
    "mobx": "^6.15.0",
    "y-protocols": "1.0.6",
    "yjs": "^13.6.30"
  },
  "peerDependenciesMeta": {
    "mobx": {
      "optional": true
    }
  }
}
