{
  "name": "@here.build/arrival-scheme",
  "version": "0.1.0",
  "description": "Scheme/LIPS interpreter for Arrival constraint-based execution",
  "keywords": [
    "scheme",
    "lisp",
    "lips",
    "interpreter",
    "sandbox",
    "s-expressions"
  ],
  "homepage": "https://github.com/here-build/foundation#readme",
  "bugs": {
    "url": "https://github.com/here-build/foundation/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/here-build/foundation.git",
    "directory": "arrival/arrival-scheme"
  },
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./oracle": {
      "types": "./dist/oracle/index.d.ts",
      "import": "./dist/oracle/index.js"
    },
    "./env": {
      "types": "./dist/env/kernel.d.ts",
      "default": "./dist/env/kernel.js"
    },
    "./capability": {
      "types": "./dist/env/capability.d.ts",
      "default": "./dist/env/capability.js"
    },
    "./resources": {
      "types": "./dist/env/resources.d.ts",
      "default": "./dist/env/resources.js"
    },
    "./scheme-env": {
      "types": "./dist/env/scheme-env.d.ts",
      "default": "./dist/env/scheme-env.js"
    },
    "./srfi": {
      "types": "./dist/env/srfi/index.d.ts",
      "default": "./dist/env/srfi/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmarks": "vitest run --config vitest.benchmarks.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@here.build/arrival-env": "workspace:^",
    "@here.build/error-invariant": "workspace:^",
    "fantasy-land": "5.0.1",
    "fold-case": "1.0.0",
    "tiny-invariant": "1.3.3",
    "unicode-properties": "1.4.1",
    "zod": "4.3.6",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@here.build/eslint-configs": "workspace:^",
    "@here.build/tsconfig": "workspace:^",
    "@types/node": "24.0.0",
    "eslint": "9.39.2",
    "fast-check": "4.8.0",
    "globals": "17.3.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.0"
  }
}
