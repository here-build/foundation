{
  "name": "@here.build/arrival-chain",
  "version": "0.1.0",
  "description": "Distributed, content-addressed, write-once inference substrate built on Plexus + arrival-scheme",
  "keywords": [
    "ai",
    "inference",
    "llm",
    "agent",
    "scheme",
    "crdt",
    "plexus",
    "arrival"
  ],
  "homepage": "https://github.com/here-build/foundation#readme",
  "bugs": {
    "url": "https://github.com/here-build/foundation/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/here-build/foundation.git",
    "directory": "arrival/arrival-chain"
  },
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "research": "vitest run --config vitest.research.config.ts",
    "custdev": "vitest run --config vitest.custdev.config.ts",
    "benchmarks": "vitest run --config vitest.benchmarks.config.ts --disableConsoleIntercept",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@here.build/arrival-inference": "workspace:^",
    "@here.build/arrival-provenance": "workspace:^",
    "@here.build/arrival-scheme": "workspace:^",
    "@here.build/arrival-sweet": "workspace:^",
    "@here.build/plexus": "workspace:^",
    "ai": "^6.0.201",
    "dedent": "1.7.2",
    "handlebars": "4.7.9",
    "jsonrepair": "3.13.0",
    "smol-toml": "1.6.1",
    "tiny-invariant": "1.3.3",
    "yaml": "2.9.0",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "mobx": "^6.15.0",
    "openai": "^5.0.1",
    "yjs": "^13.6.30"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.92.0",
    "@here.build/eslint-configs": "workspace:^",
    "@here.build/tsconfig": "workspace:^",
    "@types/node": "24.0.0",
    "@types/ws": "8.18.1",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "lib0": "0.2.114",
    "mobx": "6.15.0",
    "openai": "6.32.0",
    "prettier": "3.8.1",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.0",
    "ws": "8.18.3",
    "y-protocols": "1.0.6",
    "y-websocket": "3.0.0",
    "yjs": "13.6.30"
  }
}
