{
  "name": "@here.build/arrival-chain-view",
  "version": "0.1.0",
  "description": "Faithful, deterministic projection of arrival-chain scheme into a target language (JS first, Python next) \u2014 the read-view 'glass' over a chain program.",
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./types-emit": {
      "types": "./dist/types-emit.d.ts",
      "import": "./dist/types-emit.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@here.build/arrival-chain": "workspace:^",
    "@here.build/arrival-sweet": "workspace:^",
    "@here.build/lexical-namer": "workspace:^",
    "eslint": "9.39.2",
    "pluralize": "8.0.0",
    "prettier": "3.8.1",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@here.build/eslint-configs": "workspace:^",
    "@here.build/tsconfig": "workspace:^",
    "@types/node": "24.0.0",
    "@types/pluralize": "0.0.33",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.0"
  }
}
