{
  "name": "@here.build/arrival-scheme-env-infer",
  "version": "0.1.0",
  "description": "Palette pack: inference verbs (infer / infer-chat) + the dependent mcp-agentic pack, built on @here.build/arrival-inference",
  "keywords": [
    "arrival",
    "infer",
    "env-pack"
  ],
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "repository": {
    "type": "git",
    "url": "https://github.com/here-build/foundation.git",
    "directory": "arrival/arrival-scheme-env-infer"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!**/__tests__",
    "!**/__research__",
    "!**/__benchmarks__",
    "!**/__custdev__",
    "!**/__visual__",
    "!**/*.test.*",
    "!**/*.stories.*"
  ],
  "scripts": {
    "build": "tsc --build --force",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@here.build/arrival": "workspace:^",
    "@here.build/arrival-inference": "workspace:^",
    "tiny-invariant": "1.3.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@here.build/tsconfig": "workspace:^",
    "@types/node": "24.0.0",
    "typescript": "6.0.2",
    "vitest": "4.1.0"
  }
}
