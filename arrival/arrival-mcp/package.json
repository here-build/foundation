{
  "name": "@here.build/arrival-mcp",
  "version": "0.1.0",
  "description": "Build Model Context Protocol tools as values (discovery + action tiers) on the official SDK",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "discovery-action",
    "hono",
    "server"
  ],
  "homepage": "https://github.com/here-build/foundation#readme",
  "bugs": {
    "url": "https://github.com/here-build/foundation/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/here-build/foundation.git",
    "directory": "arrival/arrival-mcp"
  },
  "license": "FSL-1.1-MIT",
  "author": "here.build",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!**/__tests__",
    "!**/__research__",
    "!**/__benchmarks__",
    "!**/__custdev__",
    "!**/__visual__",
    "!**/*.test.*",
    "!**/*.stories.*"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@here.build/arrival": "workspace:^",
    "@here.build/arrival-serializer": "workspace:^",
    "@modelcontextprotocol/sdk": "1.26.0",
    "date-fns": "4.1.0",
    "dedent": "1.7.2",
    "hono": "4.12.0",
    "lodash-es": "4.17.23",
    "tiny-invariant": "1.3.3",
    "type-fest": "5.4.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@here.build/eslint-configs": "workspace:^",
    "@here.build/tsconfig": "workspace:^",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.0.0",
    "eslint": "9.39.2",
    "typescript": "6.0.2",
    "vitest": "4.1.0"
  }
}
